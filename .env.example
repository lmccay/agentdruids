# Druids Environment Configuration

# LLM Configuration
OPENAI_API_KEY=your-openai-api-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4

# MCP Server Configuration
# GitHub Personal Access Token for GitHub MCP Server
# Get token from: https://github.com/settings/tokens
# Required scopes: repo, read:user
GITHUB_TOKEN=ghp_your_github_token_here

# Database Configuration
DATABASE_URL=postgresql://druids_user:druids_pass_dev@druids-postgres:5432/druids

# Redis Configuration
REDIS_URL=redis://:druids_redis_dev@druids-redis:6379

# Server Configuration
PORT=3000
NODE_ENV=development

# Ollama (optional, if using local LLM instead of OpenAI)
OLLAMA_BASE_URL=http://druids-ollama:11434

# Identity / OIDC (docs/identity-and-access-control.md)
# Dev defaults target the bundled Dex container. In production, point OIDC_ISSUER
# at a real provider (Google, enterprise, KnoxIDF), set matching client creds,
# and LEAVE OIDC_INTERNAL_ISSUER UNSET (it only exists to bridge the Docker
# browser/back-channel split in local dev).
OIDC_ISSUER=http://localhost:5556/dex
OIDC_INTERNAL_ISSUER=http://druids-dex:5556/dex
OIDC_CLIENT_ID=druids
OIDC_CLIENT_SECRET=druids-dev-secret
# Auth flows through the UI origin (:3004) so the session cookie is first-party
# to the SPA; nginx proxies /auth and /api to the backend.
OIDC_REDIRECT_URI=http://localhost:3004/auth/callback
# OIDC_POST_LOGIN_REDIRECT=/        # where to send the browser after login (UI root)
# OIDC_COOKIE_SECURE=true           # set behind TLS in production

# First-admin break-glass: the first login whose OIDC subject OR email matches
# is granted the admin role. Dev Dex ships an admin@druids.dev user (pw: druids).
ADMIN_OIDC_SUBJECT=admin@druids.dev

# Session signing secret (set a strong random value in production).
SESSION_SECRET=druids-dev-session-secret

# Interim service-to-service token (replaced by RFC 8693 token exchange in P4).
INTERNAL_SERVICE_TOKEN=druids-dev-internal-token

# Optional SSRF allowlist for URL ingestion (POST /api/ingest/url). Comma-separated
# host patterns (exact or suffix, e.g. "wikipedia.org,docs.example.com"). When set,
# only matching hosts may be ingested. Private/loopback/link-local/metadata
# addresses are ALWAYS blocked regardless of this setting. Empty = any public host.
INGEST_URL_ALLOWLIST=
