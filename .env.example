# Druids Environment Configuration

# LLM Configuration
OPENAI_API_KEY=your-openai-api-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4

# MCP Server Configuration
# GitHub Personal Access Token for GitHub MCP Server
# Get token from: https://github.com/settings/tokens
# Required scopes: repo, read:user
# Note: The hosted GitHub MCP server (https://api.githubcopilot.com/mcp/) is used by default
# To use a self-hosted server, update baseUrl in config/mcp-servers.json and run: npm run mcp:github
GITHUB_TOKEN=ghp_your_github_token_here

# Database Configuration
DATABASE_URL=postgresql://druids:druids@localhost:5432/druids

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Server Configuration
PORT=3000
NODE_ENV=development
