{
  "servers": {
    "github": {
      "id": "github-mcp-server",
      "name": "GitHub MCP Server",
      "description": "Official GitHub-hosted MCP server for repository operations. For self-hosted, use http://localhost:3001/mcp",
      "transport": "sse",
      "baseUrl": "https://api.githubcopilot.com/mcp/",
      "authentication": {
        "type": "bearer",
        "tokenSource": "env",
        "envVar": "GITHUB_TOKEN",
        "header": "Authorization",
        "prefix": "Bearer "
      },
      "customHeaders": {
        "X-MCP-Toolsets": "all"
      },
      "tools": [
        "*"
      ]
    }
  },
  "realmBindings": {
    "oss-realm": {
      "servers": ["github"]
    }
  }
}
