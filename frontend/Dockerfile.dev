# Development Dockerfile for React frontend
FROM node:18-alpine

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev dependencies)
RUN npm install

# Expose port 3004
EXPOSE 3004

# Start development server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3004"]