{
  "name": "druids",
  "version": "1.0.0",
  "description": "Sophisticated multi-agent system with federated architecture",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest && npm run test:session-protection",
    "test:watch": "jest --watch",
    "test:contract": "jest tests/contract",
    "test:integration": "jest tests/integration",
    "test:unit": "jest tests/unit",
    "test:performance": "jest tests/performance",
    "test:coverage": "jest --coverage",
    "test:session-protection": "./test_session_architecture_protection.sh",
    "type-check": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "mcp:server": "ts-node src/mcp/start-mcp-server.ts",
    "mcp:github": "npx -y @modelcontextprotocol/server-github",
    "agent:create": "ts-node src/cli/createAgent.ts",
    "realm:create": "ts-node src/cli/createRealm.ts",
    "scenario:run": "ts-node src/cli/runScenario.ts",
    "docker:dev": "./scripts/dev.sh",
    "docker:test": "./scripts/test.sh",
    "health:check": "./scripts/health.sh"
  },
  "keywords": [
    "multi-agent",
    "AI",
    "LLM",
    "MCP",
    "federation",
    "TypeScript"
  ],
  "author": "Druids Project",
  "license": "Apache-2.0",
  "dependencies": {
    "@types/marked": "^5.0.2",
    "axios": "^1.5.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "gray-matter": "^4.0.3",
    "joi": "^17.10.2",
    "marked": "^17.0.2",
    "pg": "^8.16.3",
    "redis": "^5.8.2",
    "uuid": "^9.0.1",
    "winston": "^3.10.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.5",
    "@types/joi": "^17.2.3",
    "@types/node": "^20.6.0",
    "@types/pg": "^8.15.5",
    "@types/redis": "^4.0.10",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.4",
    "@types/ws": "^8.5.5",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.49.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
